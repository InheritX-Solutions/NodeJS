{
  "name": "node-backend-app",
  "version": "2.0.0",
  "description": "Production-ready Node.js backend with scalable architecture",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo \"No build step required\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prod": "ENV=production nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "generate-docs": "jsdoc -r . -c jsdoc.conf"
  },
  "nodemonConfig": {
    "ignore": [
      "uploads/*",
      "public/*"
    ]
  },
  "author": "Bansi",
  "license": "ISC",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-session": "^2.0.0",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-validator": "^7.0.1",
    "fcm-node": "^1.6.1",
    "fs-extra": "^11.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mongoose": "^8.5.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-cron": "^4.2.1",
    "request-ip": "^3.3.0",
    "serve-favicon": "^2.5.0",
    "twilio": "^4.22.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.7",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5"
  }
}
